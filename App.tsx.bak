import React, { useState, useEffect } from 'react';
import { View, Text, TextInput, TouchableOpacity, ScrollView, StyleSheet, ActivityIndicator, Alert, Platform, Dimensions, SafeAreaView, StatusBar, Modal, FlatList } from 'react-native';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { signUp, signIn, getProfile, getAllUsers, updateUserStatus, salvar, listar, checkTrial } from "./supabase";

const { width: W } = Dimensions.get('window');
const IS_WEB = Platform.OS === 'web';
const C = { navy:'#0F1C2E',navyLight:'#1A2D42',blue:'#1E6FD9',green:'#16A34A',greenLight:'#22C55E',greenBg:'#F0FDF4',orange:'#EA580C',purple:'#7C3AED',red:'#DC2626',yellow:'#CA8A04',bg:'#F1F5F9',card:'#FFFFFF',border:'#E2E8F0',muted:'#64748B',text:'#0F172A',textLight:'#94A3B8',white:'#FFFFFF' };
const MASTER = { email:'gustavocmotta22@gmail.com', senha:'Tst17334@', nome:'Gustavo Motta', role:'MASTER' };
const MENU_ITEMS = [{id:'inicio',label:'Início',icon:'⊞'},{id:'relatos',label:'Relatos',icon:'⚠️'},{id:'epi',label:'Fichas de EPI',icon:'🦺'},{id:'dds',label:'DDS',icon:'👥'},{id:'aso',label:'ASO',icon:'📄'},{id:'s2240',label:'Agentes Nocivos',icon:'🧪'},{id:'assistente',label:'Assistente NR',icon:'🤖'},{id:'admin',label:'Administração',icon:'⚙️'}];

function Chip({label,color}:any){return(<View style={{backgroundColor:color+'20',borderRadius:6,paddingHorizontal:8,paddingVertical:3}}><Text style={{color,fontSize:11,fontWeight:'700'}}>{label}</Text></View>);}

function PageHeader({title,onBack,onAdd}:any){return(<View style={s.pageHeader}><TouchableOpacity onPress={onBack} style={s.backBtn}><Text style={{color:'#FFFFFF',fontWeight:'700'}}>← Início</Text></TouchableOpacity><Text style={s.pageHeaderTitle}>{title}</Text>{onAdd?<TouchableOpacity onPress={onAdd} style={s.addBtn}><Text style={{color:'#FFFFFF',fontWeight:'700'}}>+ Novo</Text></TouchableOpacity>:<View style={{width:70}}/>}</View>);}

function Sidebar({screen,onNav,collapsed,onToggle,onLogout}:any){return(<View style={[s.sidebar,{width:collapsed?56:220}]}><View style={s.sidebarTop}>{!collapsed&&(<View style={{flexDirection:'row',alignItems:'center',flex:1}}><View style={s.sidebarLogo}><Text style={{fontSize:14}}>🛡</Text></View><View style={{marginLeft:8}}><Text style={{color:'#FFFFFF',fontWeight:'900',fontSize:15}}><Text style={{color:'#22C55E'}}>SEG</Text>TRAB</Text><Text style={{color:'#94A3B8',fontSize:9,letterSpacing:2}}>DT 22:8</Text></View></View>)}<TouchableOpacity onPress={onToggle} style={s.toggleBtn}><Text style={{color:'#94A3B8',fontSize:16,fontWeight:'700'}}>{collapsed?'›':'‹'}</Text></TouchableOpacity></View><ScrollView showsVerticalScrollIndicator={false} style={{flex:1}}>{MENU_ITEMS.map((item:any)=>{const active=screen===item.id;return(<TouchableOpacity key={item.id} onPress={()=>onNav(item.id)} style={[s.menuItem,active&&{backgroundColor:'#1E6FD9'},collapsed&&{justifyContent:'center'}]}><Text style={[{fontSize:16,width:22,textAlign:'center'},active&&{color:'#FFFFFF'}]}>{item.icon}</Text>{!collapsed&&<Text style={[s.menuLabel,active&&{color:'#FFFFFF',fontWeight:'700'}]}>{item.label}</Text>}</TouchableOpacity>);})}</ScrollView>{!collapsed&&(<TouchableOpacity onPress={onLogout} style={{flexDirection:'row',alignItems:'center',padding:14,borderTopWidth:1,borderTopColor:'#1A2D42',gap:8}}><Text style={{fontSize:16}}>🚪</Text><Text style={{color:'#94A3B8',fontSize:13}}>Sair</Text></TouchableOpacity>)}</View>);}
function LoginScreen({onLogin}:any){const[email,setEmail]=useState('');const[senha,setSenha]=useState('');const[loading,setLoading]=useState(false);const[erro,setErro]=useState('');const[tab,setTab]=useState<'login'|'cadastro'>('login');const[nome,setNome]=useState('');const[tel,setTel]=useState('');const[acT,setAcT]=useState(false);const[acL,setAcL]=useState(false);async function handleLogin(){if(!email||!senha){setErro('Preencha e-mail e senha.');return;}setLoading(true);setErro('');try{const data=await signIn(email.toLowerCase().trim(),senha);const profile=await getProfile(data.user.id);if(!profile){setErro('Perfil não encontrado.');setLoading(false);return;}const trialStatus=await checkTrial(data.user.id);await AsyncStorage.setItem('user',JSON.stringify({...profile,trialStatus}));onLogin({...profile,trialStatus});}catch(e:any){setErro(e.message==='Invalid login credentials'?'E-mail ou senha incorretos.':e.message);}setLoading(false);}async function handleCadastro(){if(!nome||!email||!senha){setErro('Preencha os campos obrigatórios.');return;}if(!acT||!acL){setErro('Aceite os Termos e a Política de Privacidade.');return;}if(senha.length<6){setErro('Senha deve ter ao menos 6 caracteres.');return;}setLoading(true);try{await signUp(email.toLowerCase().trim(),senha,nome,tel,cargo||'');setErro('');Alert.alert('Conta criada!','Verifique seu e-mail para confirmar o cadastro.',[{text:'OK',onPress:()=>{setTab('login');setLoading(false);}}]);}catch(e:any){setErro(e.message);setLoading(false);}}return(<SafeAreaView style={{flex:1,backgroundColor:'#0F1C2E'}}><StatusBar barStyle="light-content" backgroundColor="#0F1C2E"/><ScrollView contentContainerStyle={{flexGrow:1}}><View style={s.loginHeader}><View style={s.loginLogo}><Text style={{fontSize:28}}>🛡</Text></View><Text style={s.loginTitle}><Text style={{color:'#22C55E'}}>SEG</Text>TRAB</Text><Text style={{color:'rgba(255,255,255,0.5)',letterSpacing:3,fontSize:11}}>DT 22:8</Text><Text style={{color:'rgba(255,255,255,0.65)',fontSize:13,marginTop:6}}>Sistema de Gestão SST</Text><View style={s.loginTabs}>{(['login','cadastro']as const).map(t=>(<TouchableOpacity key={t} onPress={()=>{setTab(t);setErro('');}} style={[s.loginTab,tab===t&&s.loginTabActive]}><Text style={[{color:'rgba(255,255,255,0.5)',fontWeight:'600'},tab===t&&{color:'#FFFFFF',fontWeight:'800'}]}>{t==='login'?'Entrar':'Criar conta'}</Text></TouchableOpacity>))}</View></View><View style={s.loginForm}>{!!erro&&<View style={s.erroBox}><Text style={{color:'#DC2626',fontSize:13}}>{erro}</Text></View>}{tab==='login'&&(<><Text style={s.label}>E-mail</Text><TextInput style={s.input} value={email} onChangeText={setEmail} keyboardType="email-address" autoCapitalize="none" placeholder="seu@email.com" placeholderTextColor="#94A3B8"/><Text style={s.label}>Senha</Text><TextInput style={s.input} value={senha} onChangeText={setSenha} secureTextEntry placeholder="Sua senha" placeholderTextColor="#94A3B8"/><TouchableOpacity style={s.loginBtn} onPress={handleLogin} disabled={loading}>{loading?<ActivityIndicator color="#FFFFFF"/>:<Text style={{color:'#FFFFFF',fontWeight:'800',fontSize:15}}>ENTRAR</Text>}</TouchableOpacity><View style={{backgroundColor:'#F0FDF4',borderRadius:10,padding:12,marginTop:16,borderLeftWidth:3,borderLeftColor:'#16A34A'}}><Text style={{color:'#166534',fontSize:12}}>🔒 Dados protegidos pela LGPD (Lei 13.709/2018).</Text></View></>)}{tab==='cadastro'&&(<><Text style={s.label}>Nome completo *</Text><TextInput style={s.input} value={nome} onChangeText={setNome} placeholder="Seu nome" placeholderTextColor="#94A3B8"/><Text style={s.label}>E-mail *</Text><TextInput style={s.input} value={email} onChangeText={setEmail} keyboardType="email-address" autoCapitalize="none" placeholder="seu@email.com" placeholderTextColor="#94A3B8"/><Text style={s.label}>Telefone</Text><TextInput style={s.input} value={tel} onChangeText={setTel} keyboardType="phone-pad" placeholder="(00) 00000-0000" placeholderTextColor="#94A3B8"/><Text style={s.label}>Senha *</Text><TextInput style={s.input} value={senha} onChangeText={setSenha} secureTextEntry placeholder="Mínimo 6 caracteres" placeholderTextColor="#94A3B8"/><TouchableOpacity onPress={()=>setAcT(!acT)} style={s.checkRow}><View style={[s.check,acT&&{backgroundColor:'#16A34A',borderColor:'#16A34A'}]}>{acT&&<Text style={{color:'#FFFFFF',fontSize:12}}>✓</Text>}</View><Text style={{flex:1,fontSize:13,color:'#0F172A'}}>Li e aceito os <Text style={{color:'#1E6FD9',fontWeight:'700'}}>Termos de Uso</Text></Text></TouchableOpacity><TouchableOpacity onPress={()=>setAcL(!acL)} style={s.checkRow}><View style={[s.check,acL&&{backgroundColor:'#16A34A',borderColor:'#16A34A'}]}>{acL&&<Text style={{color:'#FFFFFF',fontSize:12}}>✓</Text>}</View><Text style={{flex:1,fontSize:13,color:'#0F172A'}}>Li e aceito a <Text style={{color:'#1E6FD9',fontWeight:'700'}}>Política de Privacidade</Text> (LGPD)</Text></TouchableOpacity><View style={{backgroundColor:'#EFF6FF',borderRadius:10,padding:12,marginBottom:14,borderLeftWidth:3,borderLeftColor:'#1E6FD9'}}><Text style={{color:'#1E40AF',fontSize:13,fontWeight:'800'}}>🎁 15 dias gratuitos — sem cartão</Text></View><TouchableOpacity style={[s.loginBtn,{backgroundColor:'#16A34A'}]} onPress={handleCadastro} disabled={loading}>{loading?<ActivityIndicator color="#FFFFFF"/>:<Text style={{color:'#FFFFFF',fontWeight:'800',fontSize:15}}>CRIAR CONTA</Text>}</TouchableOpacity></>)}</View></ScrollView></SafeAreaView>);}
function Dashboard({user,dados,onNav}:any){const kpis=[{label:'Fator Humano / Ato Inseguro',value:dados.relatos?.filter((r:any)=>r.tipo==='fator_humano').length||0,color:'#DC2626'},{label:'Perigo / Condição Insegura',value:dados.relatos?.filter((r:any)=>r.tipo==='perigo').length||0,color:'#EA580C'},{label:'Comportamentos Seguros',value:dados.relatos?.filter((r:any)=>r.tipo==='comportamento').length||0,color:'#16A34A'},{label:'DDS Realizados',value:dados.dds?.length||0,color:'#1E6FD9'},{label:'Fichas de EPI',value:dados.epi?.length||0,color:'#7C3AED'},{label:'ASO Registrados',value:dados.aso?.length||0,color:'#CA8A04'}];return(<ScrollView style={{flex:1,backgroundColor:'#F1F5F9'}} contentContainerStyle={{padding:16,paddingBottom:80}}><View style={s.dashCard}><Text style={{fontSize:20,fontWeight:'800',color:'#0F172A'}}>Olá, {user.nome.split(' ')[0]}! 👋</Text><Text style={{color:'#16A34A',fontWeight:'700',marginTop:2}}>SegTrab DT 22:8</Text><Text style={{color:'#64748B',fontSize:12,marginTop:2}}>Sistema de Gestão SST</Text></View><Text style={s.secLabel}>INDICADORES SST</Text><View style={{flexDirection:'row',flexWrap:'wrap',gap:10,marginBottom:20}}>{kpis.map(k=>(<View key={k.label} style={[s.kpiCard,{borderLeftColor:k.color}]}><Text style={[s.kpiValue,{color:k.color}]}>{k.value}</Text><Text style={s.kpiLabel}>{k.label}</Text></View>))}</View><Text style={s.secLabel}>AÇÕES RÁPIDAS</Text><ScrollView horizontal showsHorizontalScrollIndicator={false} style={{marginBottom:20}}><View style={{flexDirection:'row',gap:10}}>{[{label:'Novo Relato',icon:'🚨',color:'#0F1C2E',screen:'novo_relato'},{label:'Ficha EPI',icon:'🦺',color:'#EA580C',screen:'nova_epi'},{label:'DDS',icon:'👥',color:'#1E6FD9',screen:'novo_dds'},{label:'Assistente NR',icon:'🤖',color:'#7C3AED',screen:'assistente'},{label:'ASO',icon:'📄',color:'#16A34A',screen:'aso'}].map(a=>(<TouchableOpacity key={a.screen} onPress={()=>onNav(a.screen)} style={[s.actionCard,{backgroundColor:a.color}]}><Text style={{fontSize:22,marginBottom:8}}>{a.icon}</Text><Text style={{color:'#FFFFFF',fontWeight:'800',fontSize:13}}>{a.label}</Text></TouchableOpacity>))}</View></ScrollView><Text style={s.secLabel}>MÓDULOS</Text>{[{icon:'⚠',label:'Relatos de Campo',val:dados.relatos?.length||0,color:'#DC2626',screen:'relatos'},{icon:'🦺',label:'Fichas de EPI',val:dados.epi?.length||0,color:'#EA580C',screen:'epi'},{icon:'👥',label:'DDS',val:dados.dds?.length||0,color:'#1E6FD9',screen:'dds'},{icon:'📄',label:'ASO',val:dados.aso?.length||0,color:'#16A34A',screen:'aso'},{icon:'⚗',label:'Agentes Nocivos S-2240',val:dados.agentes?.length||0,color:'#7C3AED',screen:'s2240'},{icon:'🤖',label:'Assistente NR (IA)',val:null,color:'#0F1C2E',screen:'assistente'}].map(m=>(<TouchableOpacity key={m.screen} onPress={()=>onNav(m.screen)} style={s.moduleCard}><View style={[s.moduleIcon,{backgroundColor:m.color+'20'}]}><Text style={{fontSize:18}}>{m.icon}</Text></View><Text style={s.moduleLabel}>{m.label}</Text>{m.val!==null&&<Text style={[s.moduleVal,{color:m.color}]}>{m.val}</Text>}<Text style={{color:'#64748B',fontSize:20}}>›</Text></TouchableOpacity>))}</ScrollView>);}
function ListaScreen({title,items,onBack,novoScreen,onNav,renderCard}:any){return(<View style={{flex:1,backgroundColor:'#F1F5F9'}}><PageHeader title={title} onBack={onBack} onAdd={()=>onNav(novoScreen)}/><FlatList data={items} keyExtractor={(_,i)=>i.toString()} contentContainerStyle={{padding:16,paddingBottom:80}} ListEmptyComponent={<View style={{alignItems:'center',padding:40}}><Text style={{fontSize:40,marginBottom:12}}>📋</Text><Text style={{fontSize:16,fontWeight:'700',color:'#0F172A',marginBottom:6}}>Nenhum registro</Text><Text style={{color:'#64748B',textAlign:'center'}}>Toque em "+ Novo" para adicionar.</Text></View>} renderItem={({item})=>renderCard(item)}/></View>);}
function FormSimples({title,campos,onBack,onSalvar}:any){const[vals,setVals]=useState<any>({});const[loading,setLoading]=useState(false);async function salvar(){const obrig=campos.filter((c:any)=>c.label.includes('*'));for(const c of obrig){if(!vals[c.key]){Alert.alert('Atenção',`Preencha: ${c.label.replace(' *','')}`);return;}}setLoading(true);await new Promise(r=>setTimeout(r,400));await onSalvar(vals);setLoading(false);}return(<View style={{flex:1,backgroundColor:'#F1F5F9'}}><PageHeader title={title} onBack={onBack}/><ScrollView contentContainerStyle={{padding:16,paddingBottom:80}}><View style={s.formCard}>{campos.map((c:any)=>(<View key={c.key}><Text style={s.label}>{c.label}</Text><TextInput style={s.input} value={vals[c.key]||''} onChangeText={v=>setVals((p:any)=>({...p,[c.key]:v}))} placeholder={c.placeholder} placeholderTextColor="#94A3B8"/></View>))}<TouchableOpacity style={s.saveBtn} onPress={salvar} disabled={loading}>{loading?<ActivityIndicator color="#FFFFFF"/>:<Text style={{color:'#FFFFFF',fontWeight:'800',fontSize:15}}>Salvar</Text>}</TouchableOpacity></View></ScrollView></View>);}
function FormRelato({onSalvar,onBack}:any){const[tipo,setTipo]=useState('');const[descricao,setDescricao]=useState('');const[local,setLocal]=useState('');const[criticidade,setCriticidade]=useState('');const[loading,setLoading]=useState(false);const TIPOS=[{val:'fator_humano',label:'Fator Humano / Ato Inseguro'},{val:'perigo',label:'Perigo / Condição Insegura'},{val:'comportamento',label:'Comportamento Seguro'},{val:'quase_acidente',label:'Quase Acidente / Incidente'},{val:'acidente',label:'Acidente de Trabalho'}];const CRITS=[{val:'baixo',label:'Baixo',color:'#16A34A'},{val:'medio',label:'Médio',color:'#CA8A04'},{val:'grave',label:'Grave',color:'#EA580C'},{val:'gravissimo',label:'Gravíssimo',color:'#DC2626'}];async function salvar(){if(!tipo||!descricao||!local||!criticidade){Alert.alert('Atenção','Preencha todos os campos.');return;}setLoading(true);await new Promise(r=>setTimeout(r,400));onSalvar({tipo,descricao,local,criticidade,data:new Date().toLocaleDateString('pt-BR')});setLoading(false);}return(<View style={{flex:1,backgroundColor:'#F1F5F9'}}><PageHeader title="Novo Relato" onBack={onBack}/><ScrollView contentContainerStyle={{padding:16,paddingBottom:80}}><View style={s.formCard}><Text style={s.label}>Tipo de Ocorrência *</Text><ScrollView horizontal showsHorizontalScrollIndicator={false} style={{marginBottom:14}}><View style={{flexDirection:'row',gap:8}}>{TIPOS.map(t=>(<TouchableOpacity key={t.val} onPress={()=>setTipo(t.val)} style={[s.chip,tipo===t.val&&{backgroundColor:'#0F1C2E',borderColor:'#0F1C2E'}]}><Text style={[s.chipText,tipo===t.val&&{color:'#FFFFFF'}]}>{t.label}</Text></TouchableOpacity>))}</View></ScrollView><Text style={s.label}>Criticidade *</Text><View style={{flexDirection:'row',gap:8,marginBottom:14,flexWrap:'wrap'}}>{CRITS.map(c=>(<TouchableOpacity key={c.val} onPress={()=>setCriticidade(c.val)} style={[s.chip,criticidade===c.val&&{backgroundColor:c.color,borderColor:c.color}]}><Text style={[s.chipText,criticidade===c.val&&{color:'#FFFFFF'}]}>{c.label}</Text></TouchableOpacity>))}</View><Text style={s.label}>Local / Setor *</Text><TextInput style={s.input} value={local} onChangeText={setLocal} placeholder="Ex: Cozinha, Produção" placeholderTextColor="#94A3B8"/><Text style={s.label}>Descrição *</Text><TextInput style={[s.input,{height:100,textAlignVertical:'top',paddingTop:10}]} value={descricao} onChangeText={setDescricao} multiline placeholder="Descreva o ocorrido..." placeholderTextColor="#94A3B8"/><TouchableOpacity style={s.saveBtn} onPress={salvar} disabled={loading}>{loading?<ActivityIndicator color="#FFFFFF"/>:<Text style={{color:'#FFFFFF',fontWeight:'800',fontSize:15}}>Salvar Relato</Text>}</TouchableOpacity></View></ScrollView></View>);}
function AssistenteScreen({onBack}:any){const[msgs,setMsgs]=useState<any[]>([]);const[input,setInput]=useState('');const[loading,setLoading]=useState(false);const SUGESTOES=['Quais EPIs são obrigatórios para trabalho em altura?','CIPA é obrigatória com 25 funcionários?','Como preencher o S-2240 para ruído?','Adicional de insalubridade para calor?'];async function enviar(texto?:string){const t=(texto||input).trim();if(!t||loading)return;setInput('');const nm=[...msgs,{role:'user',text:t}];setMsgs(nm);setLoading(true);try{const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1000,system:'Especialista SST Brasil. Fundamente em NRs, CLT, ISO 45001 e jurisprudência TST/STF. Use terminologia ISO 45001 com termo legado entre parênteses. Responda em português.',messages:nm.map(m=>({role:m.role==='ai'?'assistant':'user',content:m.text}))})});const data=await res.json();setMsgs(p=>[...p,{role:'ai',text:data?.content?.[0]?.text||'Erro na resposta.'}]);}catch{setMsgs(p=>[...p,{role:'ai',text:'❌ Erro de conexão.'}]);}setLoading(false);}return(<View style={{flex:1,backgroundColor:'#F1F5F9'}}><PageHeader title="Assistente NR" onBack={onBack}/><View style={{backgroundColor:'#0F1C2E',padding:8}}><Text style={{color:'rgba(255,255,255,0.5)',fontSize:11,textAlign:'center'}}>Fundamentado em NRs · CLT · ISO 45001 · TST/STF</Text></View><ScrollView style={{flex:1,padding:16}} contentContainerStyle={{paddingBottom:16}}>{msgs.length===0&&(<View><Text style={{fontSize:13,color:'#64748B',textAlign:'center',marginBottom:12}}>Sugestões:</Text>{SUGESTOES.map(sg=>(<TouchableOpacity key={sg} onPress={()=>enviar(sg)} style={{backgroundColor:'#FFFFFF',borderRadius:12,padding:14,marginBottom:8,borderWidth:1,borderColor:'#E2E8F0'}}><Text style={{fontSize:13,color:'#0F172A'}}>{sg}</Text></TouchableOpacity>))}</View>)}{msgs.map((m,i)=>(<View key={i} style={m.role==='user'?{backgroundColor:'#0F1C2E',borderRadius:16,borderBottomRightRadius:4,padding:12,marginBottom:10,marginLeft:40}:{backgroundColor:'#FFFFFF',borderRadius:16,borderBottomLeftRadius:4,padding:14,marginBottom:10,marginRight:40,borderWidth:1,borderColor:'#E2E8F0'}}>{m.role==='ai'&&<Text style={{fontSize:11,color:'#64748B',fontWeight:'600',marginBottom:4}}>🤖 Assistente NR</Text>}<Text style={{color:m.role==='user'?'#FFFFFF':'#0F172A',fontSize:14,lineHeight:22}}>{m.text}</Text></View>))}{loading&&<View style={{backgroundColor:'#FFFFFF',borderRadius:16,padding:12,marginBottom:10,borderWidth:1,borderColor:'#E2E8F0'}}><Text style={{color:'#64748B'}}>Consultando legislação...</Text></View>}</ScrollView><View style={{flexDirection:'row',padding:10,backgroundColor:'#FFFFFF',borderTopWidth:1,borderTopColor:'#E2E8F0',gap:8,alignItems:'flex-end'}}><TextInput style={{flex:1,backgroundColor:'#F1F5F9',borderRadius:12,padding:10,fontSize:14,color:'#0F172A',maxHeight:100}} value={input} onChangeText={setInput} placeholder="Pergunte sobre NRs, CLT, SST..." placeholderTextColor="#94A3B8" multiline/><TouchableOpacity style={{width:42,height:42,borderRadius:12,backgroundColor:'#0F1C2E',alignItems:'center',justifyContent:'center'}} onPress={()=>enviar()}><Text style={{color:'#FFFFFF',fontSize:20}}>↑</Text></TouchableOpacity></View></View>);}
function AdminScreen({user,onBack,onLogout}:any){return(<View style={{flex:1,backgroundColor:'#F1F5F9'}}><PageHeader title="Administração" onBack={onBack}/><ScrollView contentContainerStyle={{padding:16,paddingBottom:80}}><View style={s.formCard}><Text style={{fontSize:16,fontWeight:'800',color:'#0F172A',marginBottom:4}}>Perfil</Text><Text style={{color:'#64748B',marginBottom:2}}>{user.nome}</Text><Text style={{color:'#64748B',marginBottom:12}}>{user.email}</Text><View style={{backgroundColor:'#EFF6FF',borderRadius:8,paddingHorizontal:10,paddingVertical:5,alignSelf:'flex-start',marginBottom:16}}><Text style={{color:'#1E6FD9',fontWeight:'700'}}>{user.role}</Text></View>{user.role==='MASTER'&&(<View style={{backgroundColor:'#F0FDF4',borderRadius:10,padding:14,marginBottom:14,borderLeftWidth:3,borderLeftColor:'#16A34A'}}><Text style={{color:'#16A34A',fontWeight:'800',fontSize:14,marginBottom:4}}>Painel Master</Text><Text style={{color:'#166534',fontSize:13}}>Acesso completo ao SegTrab DT 22:8.</Text></View>)}<TouchableOpacity onPress={onLogout} style={[s.saveBtn,{backgroundColor:'#DC2626'}]}><Text style={{color:'#FFFFFF',fontWeight:'800',fontSize:15}}>Sair do Sistema</Text></TouchableOpacity></View><View style={[s.formCard,{marginTop:14}]}><Text style={{fontSize:15,fontWeight:'800',color:'#0F172A',marginBottom:8}}>Planos disponíveis</Text>{[{nome:'Starter',valor:'R$ 49/mês',desc:'1 usuário · Relatos, DDS, Biblioteca'},{nome:'Essencial',valor:'R$ 99/mês',desc:'Até 3 usuários · + EPI, Dashboard'},{nome:'Professional ⭐',valor:'R$ 199/mês',desc:'Até 10 usuários · + IA SST, Inspeções'}].map(p=>(<View key={p.nome} style={{borderWidth:1,borderColor:'#E2E8F0',borderRadius:10,padding:12,marginBottom:8}}><View style={{flexDirection:'row',justifyContent:'space-between',marginBottom:2}}><Text style={{fontWeight:'700',color:'#0F172A'}}>{p.nome}</Text><Text style={{fontWeight:'800',color:'#1E6FD9'}}>{p.valor}</Text></View><Text style={{color:'#64748B',fontSize:12}}>{p.desc}</Text></View>))}</View></ScrollView></View>);}
export default function App(){const[user,setUser]=useState<any>(null);const[loading,setLoading]=useState(true);const[screen,setScreen]=useState('inicio');const[collapsed,setCollapsed]=useState(false);const[drawerOpen,setDrawerOpen]=useState(false);const[dados,setDados]=useState<any>({relatos:[],epi:[],dds:[],aso:[],agentes:[]});useEffect(()=>{AsyncStorage.getItem('user').then(d=>{if(d)setUser(JSON.parse(d));setLoading(false);});},[]);useEffect(()=>{if(user)carregarDados();},[user]);async function carregarDados(){if(!user?.id)return;try{const[r,e,d,a,ag]=await Promise.all([listar('relatos',user.id),listar('epis',user.id),listar('dds',user.id),listar('asos',user.id),listar('agentes',user.id)]);setDados({relatos:r,epi:e,dds:d,aso:a,agentes:ag});}catch(err){console.log('erro ao carregar',err);}}async function salvarItem(tipo:string,item:any){if(!user?.id)return;await salvar(tipo,item,user.id);await carregarDados();});}async function logout(){await AsyncStorage.removeItem('user');setUser(null);setScreen('inicio');}function nav(sc:string){setScreen(sc);setDrawerOpen(false);}if(loading)return(<View style={{flex:1,backgroundColor:'#0F1C2E',alignItems:'center',justifyContent:'center'}}><Text style={{fontSize:40,marginBottom:12}}>🛡</Text><Text style={{color:'#FFFFFF',fontWeight:'900',fontSize:24}}><Text style={{color:'#22C55E'}}>SEG</Text>TRAB</Text><ActivityIndicator color="#FFFFFF" style={{marginTop:20}}/></View>);if(!user)return <LoginScreen onLogin={(u:any)=>setUser(u)}/>;function renderContent(){switch(screen){case'inicio':return <Dashboard user={user} dados={dados} onNav={nav}/>;case'relatos':return <ListaScreen title="Relatos" items={dados.relatos} onBack={()=>nav('inicio')} novoScreen="novo_relato" onNav={nav} renderCard={(r:any)=>(<View style={s.listCard}><View style={{flexDirection:'row',justifyContent:'space-between',marginBottom:4}}><Text style={{fontWeight:'700',color:'#0F172A',flex:1}}>{r.tipo?.replace('_',' ').toUpperCase()}</Text><Chip label={r.criticidade} color={r.criticidade==='gravissimo'?'#DC2626':r.criticidade==='grave'?'#EA580C':'#CA8A04'}/></View><Text style={{color:'#64748B',fontSize:13}}>{r.local} · {r.data}</Text><Text style={{color:'#0F172A',fontSize:13,marginTop:4}} numberOfLines={2}>{r.descricao}</Text></View>)}/>;case'novo_relato':return <FormRelato onBack={()=>nav('relatos')} onSalvar={async(d:any)=>{await salvarItem('relatos',d);nav('relatos');}}/>;case'epi':return <ListaScreen title="Fichas de EPI" items={dados.epi} onBack={()=>nav('inicio')} novoScreen="nova_epi" onNav={nav} renderCard={(e:any)=>(<View style={s.listCard}><Text style={{fontWeight:'700',color:'#0F172A',marginBottom:2}}>{e.colaborador}</Text><Text style={{color:'#64748B',fontSize:13}}>{e.cargo}</Text><Text style={{color:'#64748B',fontSize:13}}>EPI: {e.item} · CA: {e.ca||'-'}</Text></View>)}/>;case'nova_epi':return <FormSimples title="Nova Entrega EPI" campos={[{key:'colaborador',label:'Colaborador *',placeholder:'Nome completo'},{key:'cargo',label:'Cargo',placeholder:'Ex: Auxiliar de produção'},{key:'item',label:'Item de EPI *',placeholder:'Ex: Capacete de segurança'},{key:'ca',label:'Número do CA',placeholder:'Ex: 12345'}]} onBack={()=>nav('epi')} onSalvar={async(d:any)=>{await salvarItem('epi',d);nav('epi');}}/>;case'dds':return <ListaScreen title="DDS" items={dados.dds} onBack={()=>nav('inicio')} novoScreen="novo_dds" onNav={nav} renderCard={(d:any)=>(<View style={s.listCard}><Text style={{fontWeight:'700',color:'#0F172A',marginBottom:2}}>{d.tema}</Text><Text style={{color:'#64748B',fontSize:13}}>Ministrante: {d.ministrante}</Text><Text style={{color:'#64748B',fontSize:13}}>Participantes: {d.participantes||0} · {d.data}</Text></View>)}/>;case'novo_dds':return <FormSimples title="Novo DDS" campos={[{key:'tema',label:'Tema *',placeholder:'Ex: Trabalho em Altura — NR-35'},{key:'ministrante',label:'Ministrante *',placeholder:'Nome do responsável'},{key:'participantes',label:'Nº de Participantes',placeholder:'Ex: 12'},{key:'duracao',label:'Duração (min)',placeholder:'Ex: 15'}]} onBack={()=>nav('dds')} onSalvar={async(d:any)=>{await salvarItem('dds',{...d,data:new Date().toLocaleDateString('pt-BR')});nav('dds');}}/>;case'aso':return <ListaScreen title="ASO" items={dados.aso} onBack={()=>nav('inicio')} novoScreen="novo_aso" onNav={nav} renderCard={(a:any)=>(<View style={s.listCard}><View style={{flexDirection:'row',justifyContent:'space-between',marginBottom:2}}><Text style={{fontWeight:'700',color:'#0F172A'}}>{a.colaborador}</Text><Chip label={a.tipo} color="#16A34A"/></View><Text style={{color:'#64748B',fontSize:13}}>Validade: {a.validade}</Text><Text style={{color:'#64748B',fontSize:13}}>Resultado: {a.resultado}</Text></View>)}/>;case'novo_aso':return <FormSimples title="Novo ASO" campos={[{key:'colaborador',label:'Colaborador *',placeholder:'Nome completo'},{key:'cargo',label:'Cargo',placeholder:'Ex: Operador de Máquinas'},{key:'tipo',label:'Tipo *',placeholder:'Admissional / Periódico / Demissional'},{key:'validade',label:'Validade *',placeholder:'Ex: 31/12/2026'},{key:'resultado',label:'Resultado',placeholder:'Apto / Inapto'}]} onBack={()=>nav('aso')} onSalvar={async(d:any)=>{await salvarItem('aso',d);nav('aso');}}/>;case's2240':return <ListaScreen title="Agentes Nocivos" items={dados.agentes} onBack={()=>nav('inicio')} novoScreen="novo_agente" onNav={nav} renderCard={(a:any)=>(<View style={s.listCard}><View style={{flexDirection:'row',justifyContent:'space-between',marginBottom:2}}><Text style={{fontWeight:'700',color:'#0F172A'}}>{a.nome}</Text><Chip label={a.tipo} color="#7C3AED"/></View><Text style={{color:'#64748B',fontSize:13}}>Setor: {a.setor}</Text>{a.epi&&<Text style={{color:'#64748B',fontSize:13}}>EPI: {a.epi}</Text>}</View>)}/>;case'novo_agente':return <FormSimples title="Novo Agente Nocivo" campos={[{key:'nome',label:'Nome do Agente *',placeholder:'Ex: Ruído contínuo'},{key:'tipo',label:'Tipo *',placeholder:'Físico / Químico / Biológico / Ergonômico'},{key:'setor',label:'Setor',placeholder:'Ex: Produção'},{key:'intensidade',label:'Intensidade',placeholder:'Ex: 87 dB(A)'},{key:'epi',label:'EPI (CA)',placeholder:'Ex: Protetor auricular CA 12345'}]} onBack={()=>nav('s2240')} onSalvar={async(d:any)=>{await salvarItem('agentes',d);nav('s2240');}}/>;case'assistente':return <AssistenteScreen onBack={()=>nav('inicio')}/>;case'admin':return <AdminScreen user={user} onBack={()=>nav('inicio')} onLogout={logout}/>;default:return <Dashboard user={user} dados={dados} onNav={nav}/>;}}const topBar=(<View style={s.topBar}>{!IS_WEB&&(<TouchableOpacity onPress={()=>setDrawerOpen(true)} style={{marginRight:12}}><Text style={{color:'#FFFFFF',fontSize:22}}>☰</Text></TouchableOpacity>)}<Text style={{color:'#FFFFFF',fontWeight:'900',fontSize:16}}><Text style={{color:'#22C55E'}}>SEG</Text>TRAB <Text style={{color:'#94A3B8',fontSize:12}}>DT 22:8</Text></Text><View style={{marginLeft:'auto' as any,flexDirection:'row',alignItems:'center',gap:10}}><View style={{flexDirection:'row',alignItems:'center',gap:4,backgroundColor:'#1A2D42',borderRadius:20,paddingHorizontal:10,paddingVertical:4}}><View style={{width:6,height:6,borderRadius:3,backgroundColor:'#22C55E'}}/><Text style={{color:'#FFFFFF',fontSize:11,fontWeight:'600'}}>Online</Text></View><TouchableOpacity onPress={()=>nav('admin')} style={{width:32,height:32,borderRadius:16,backgroundColor:'#1E6FD9',alignItems:'center',justifyContent:'center'}}><Text style={{color:'#FFFFFF',fontWeight:'800'}}>{user.nome[0]}</Text></TouchableOpacity></View></View>);if(IS_WEB){return(<View style={{flex:1,flexDirection:'row',backgroundColor:'#F1F5F9'}}><Sidebar screen={screen} onNav={nav} collapsed={collapsed} onToggle={()=>setCollapsed(!collapsed)} onLogout={logout}/><View style={{flex:1}}>{topBar}{renderContent()}</View></View>);}return(<SafeAreaView style={{flex:1,backgroundColor:'#0F1C2E'}}><StatusBar barStyle="light-content" backgroundColor="#0F1C2E"/>{topBar}<Modal visible={drawerOpen} transparent animationType="slide" onRequestClose={()=>setDrawerOpen(false)}><View style={{flex:1,flexDirection:'row'}}><Sidebar screen={screen} onNav={nav} collapsed={false} onToggle={()=>setDrawerOpen(false)} onLogout={logout}/><TouchableOpacity style={{flex:1,backgroundColor:'rgba(0,0,0,0.5)'}} onPress={()=>setDrawerOpen(false)}/></View></Modal><View style={{flex:1}}>{renderContent()}</View><View style={s.bottomNav}>{[{id:'inicio',label:'Início',icon:'⊞'},{id:'relatos',label:'Relatos',icon:'⚠️'},{id:'novo_relato',label:'',icon:'+',fab:true},{id:'assistente',label:'IA SST',icon:'🤖'},{id:'admin',label:'Admin',icon:'⚙'}].map(t=>t.fab?<TouchableOpacity key="fab" style={s.fab} onPress={()=>nav('novo_relato')}><Text style={{color:'#FFFFFF',fontSize:26}}>+</Text></TouchableOpacity>:<TouchableOpacity key={t.id} style={s.bottomTab} onPress={()=>nav(t.id)}><Text style={{fontSize:18}}>{t.icon}</Text><Text style={{fontSize:10,color:screen===t.id?'#1E6FD9':'#64748B',fontWeight:screen===t.id?'700':'400',marginTop:2}}>{t.label}</Text></TouchableOpacity>)}</View></SafeAreaView>);}
const s=StyleSheet.create({loginHeader:{backgroundColor:'#0F1C2E',paddingTop:52,paddingBottom:0,paddingHorizontal:24,alignItems:'center'},loginLogo:{width:64,height:64,borderRadius:20,backgroundColor:'rgba(255,255,255,0.15)',alignItems:'center',justifyContent:'center',marginBottom:12},loginTitle:{fontSize:32,fontWeight:'900',color:'#FFFFFF'},loginTabs:{flexDirection:'row',borderTopWidth:1,borderTopColor:'rgba(255,255,255,0.15)',width:'100%',marginTop:20},loginTab:{flex:1,paddingVertical:13,alignItems:'center'},loginTabActive:{borderBottomWidth:3,borderBottomColor:'#22C55E'},loginForm:{backgroundColor:'#F1F5F9',flex:1,padding:22,paddingBottom:40},erroBox:{backgroundColor:'#FEF2F2',borderRadius:10,padding:12,marginBottom:12,borderLeftWidth:3,borderLeftColor:'#DC2626'},label:{fontSize:12,fontWeight:'700',color:'#64748B',marginBottom:5,textTransform:'uppercase',letterSpacing:0.5},input:{height:50,borderRadius:12,borderWidth:1.5,borderColor:'#E2E8F0',backgroundColor:'#FFFFFF',paddingHorizontal:14,fontSize:14,color:'#0F172A',marginBottom:12},loginBtn:{backgroundColor:'#0F1C2E',borderRadius:12,paddingVertical:14,alignItems:'center',marginTop:4},checkRow:{flexDirection:'row',alignItems:'flex-start',gap:10,marginBottom:10,padding:10,backgroundColor:'#FFFFFF',borderRadius:10,borderWidth:1,borderColor:'#E2E8F0'},check:{width:22,height:22,borderRadius:6,borderWidth:2,borderColor:'#E2E8F0',alignItems:'center',justifyContent:'center',flexShrink:0},dashCard:{backgroundColor:'#FFFFFF',borderRadius:16,padding:18,marginBottom:16},secLabel:{fontSize:11,fontWeight:'700',color:'#64748B',letterSpacing:1.5,textTransform:'uppercase',marginBottom:10},kpiCard:{flex:1,minWidth:140,backgroundColor:'#FFFFFF',borderRadius:14,padding:14,borderLeftWidth:4},kpiValue:{fontSize:28,fontWeight:'900'},kpiLabel:{fontSize:11,color:'#64748B',marginTop:4,lineHeight:14},actionCard:{width:130,borderRadius:14,padding:14},moduleCard:{backgroundColor:'#FFFFFF',borderRadius:14,padding:14,marginBottom:10,flexDirection:'row',alignItems:'center'},moduleIcon:{width:40,height:40,borderRadius:12,alignItems:'center',justifyContent:'center',marginRight:12},moduleLabel:{flex:1,fontSize:14,fontWeight:'600',color:'#0F172A'},moduleVal:{fontSize:22,fontWeight:'900',marginRight:8},pageHeader:{backgroundColor:'#0F1C2E',paddingTop:14,paddingBottom:14,paddingHorizontal:14,flexDirection:'row',alignItems:'center'},pageHeaderTitle:{color:'#FFFFFF',fontWeight:'800',fontSize:16,flex:1,textAlign:'center'},backBtn:{backgroundColor:'rgba(255,255,255,0.15)',borderRadius:8,paddingHorizontal:12,paddingVertical:6},addBtn:{backgroundColor:'#1E6FD9',borderRadius:8,paddingHorizontal:12,paddingVertical:6},listCard:{backgroundColor:'#FFFFFF',borderRadius:14,padding:16,marginBottom:10,borderWidth:1,borderColor:'#E2E8F0'},formCard:{backgroundColor:'#FFFFFF',borderRadius:16,padding:18},chip:{borderRadius:20,paddingHorizontal:12,paddingVertical:7,borderWidth:1,borderColor:'#E2E8F0',backgroundColor:'#FFFFFF'},chipText:{fontSize:12,color:'#0F172A',fontWeight:'600'},saveBtn:{backgroundColor:'#16A34A',borderRadius:12,paddingVertical:14,alignItems:'center',marginTop:8},sidebar:{backgroundColor:'#0F1C2E',borderRightWidth:1,borderRightColor:'#1A2D42',overflow:'hidden'},sidebarTop:{flexDirection:'row',alignItems:'center',padding:14,paddingTop:18,borderBottomWidth:1,borderBottomColor:'#1A2D42',marginBottom:4},sidebarLogo:{width:30,height:30,borderRadius:8,backgroundColor:'#16A34A',alignItems:'center',justifyContent:'center'},toggleBtn:{width:26,height:26,borderRadius:7,backgroundColor:'#1A2D42',alignItems:'center',justifyContent:'center',marginLeft:'auto' as any},menuItem:{flexDirection:'row',alignItems:'center',paddingHorizontal:12,paddingVertical:9,borderRadius:10,marginHorizontal:6,marginVertical:1},menuLabel:{marginLeft:10,fontSize:13,color:'#94A3B8',fontWeight:'500'},topBar:{flexDirection:'row',alignItems:'center',backgroundColor:'#0F1C2E',paddingHorizontal:16,paddingVertical:12,borderBottomWidth:1,borderBottomColor:'#1A2D42'},bottomNav:{flexDirection:'row',backgroundColor:'#FFFFFF',borderTopWidth:1,borderTopColor:'#E2E8F0',paddingBottom:8,paddingTop:8,alignItems:'center',justifyContent:'space-around'},bottomTab:{flex:1,alignItems:'center',paddingVertical:4},fab:{width:52,height:52,borderRadius:26,backgroundColor:'#1E6FD9',alignItems:'center',justifyContent:'center',marginTop:-20}});